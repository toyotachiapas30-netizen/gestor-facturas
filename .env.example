# ── CONFIGURACIÓN DEL SERVIDOR ──────────────────────────────
PORT=3001
NODE_ENV=production

# ── SUPABASE (Base de Datos) ──────────────────────────────────
# Consigue estos datos en tu proyecto de Supabase (Settings > API)
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_KEY=tu-anon-key-de-supabase

# ── GOOGLE API ────────────────────────────────────────────────
# Consigue estos en Google Cloud Console
GOOGLE_CLIENT_ID=tu-google-client-id
GOOGLE_CLIENT_SECRET=tu-google-client-secret
GOOGLE_REDIRECT_URI=https://tu-app.onrender.com/api/drive/callback

# Estos se generarán automáticamente cuando inicies sesión
GOOGLE_REFRESH_TOKEN=tu-refresh-token

# ── PUPPETEER (Navegador) ─────────────────────────────────────
# En Mac no lo necesitas, en Render se usará /usr/bin/google-chrome-stable
PUPPETEER_EXECUTABLE_PATH=/usr/bin/google-chrome-stable
